{
  "name": "profiler-md",
  "version": "0.0.2",
  "author": {
    "name": "Tomer Aberbach",
    "email": "tomer@aberba.ch",
    "url": "https://tomeraberba.ch"
  },
  "description": "Converts performance profiles to human and LLM friendly Markdown.",
  "keywords": [
    "ai",
    "bun",
    "chrome",
    "cli",
    "cpu",
    "deno",
    "deopt",
    "deoptimization",
    "devtools",
    "heap",
    "llm",
    "markdown",
    "md",
    "node",
    "optimization",
    "perf",
    "performance",
    "pretty",
    "profile",
    "profiler",
    "snapshot",
    "speedscope",
    "timing",
    "v8"
  ],
  "homepage": "https://github.com/TomerAberbach/profiler-md",
  "repository": "TomerAberbach/profiler-md",
  "bugs": {
    "url": "https://github.com/TomerAberbach/profiler-md/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/TomerAberbach"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">= 22"
  },
  "bin": {
    "profiler-md": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format:base": "prettier --cache --write",
    "format": "pnpm format:base .",
    "lint:base": "eslint --cache --cache-location node_modules/.cache/eslint/ --fix",
    "lint": "pnpm lint:base .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "bench": "./scripts/bench",
    "build": "tsdown",
    "update-readme": "node scripts/update-readme.ts",
    "check-readme": "node scripts/update-readme.ts --check",
    "update-examples": "node scripts/update-examples.ts",
    "check-examples": "node scripts/update-examples.ts --check",
    "prepublishOnly": "pnpm build"
  },
  "prettier": "@tomer/prettier-config",
  "dependencies": {
    "meow": "^14.1.0",
    "picomatch": "^4.0.4",
    "plur": "^6.0.0",
    "pprof-format": "^2.2.1",
    "pretty-bytes": "^7.1.0",
    "pretty-ms": "^9.3.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@tomer/eslint-config": "^5.0.0",
    "@tomer/prettier-config": "^4.0.1",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "diff": "^9.0.0",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "rollup-plugin-tree-shakeable": "^2.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
